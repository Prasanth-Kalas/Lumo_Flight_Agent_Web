# Flight Agent environment.

# Duffel sandbox — get a key from https://app.duffel.com
# Use a _test_ token in preview / sandbox. Only switch to a live token after
# Duffel live-mode activation and US Seller-of-Travel compliance sign-off.
DUFFEL_ACCESS_TOKEN=duffel_test_REPLACE_ME

# Public base URL this agent is reachable at. The shell's registry uses this
# to discover /.well-known/agent.json + /openapi.json + /api/health. It also
# gets baked into the manifest itself so downstream consumers can link back.
#
# Dev:      http://localhost:3002
# Vercel:   https://<your-flight-project>.vercel.app
# Prod DNS: https://flight.agents.lumo.rentals
#
# NOTE: do NOT use Vercel's auto-injected VERCEL_URL — that's the per-deploy
# preview URL, not the stable public one. Pin the production URL explicitly.
LUMO_AGENT_PUBLIC_URL=http://localhost:3002
